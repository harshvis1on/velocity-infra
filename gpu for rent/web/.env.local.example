# ─── Supabase (Dashboard > Project Settings > API) ───
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Razorpay (Dashboard > Settings > API Keys) ───
RAZORPAY_KEY_ID=rzp_test_XXXXX
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_XXXXX
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret-from-razorpay-dashboard

# ─── Twilio (for phone OTP) ───
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ─── Cron / Admin Endpoints ───
# Required for auto-topup, payout generation, and other scheduled tasks.
# Generate a strong random secret: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here